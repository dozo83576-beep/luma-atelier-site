---
import { advantages } from "../../data/content";
---

<section id="advantages" class="bg-[var(--color-linen)] flex min-h-[100svh] flex-col justify-center py-[var(--spacing-section)] text-[var(--color-ink)]">
  <div class="container-luma">
    <div class="reveal flex items-center gap-4">
      <span class="font-mono text-[0.6875rem] font-medium tracking-[0.18em] text-[var(--color-accent-deep)]">{advantages.index}</span>
      <span class="font-mono text-[0.6875rem] font-medium uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">{advantages.label}</span>
      <span class="h-px max-w-[120px] flex-1 bg-[var(--color-ink)]/15"></span>
    </div>

    <div class="mt-10 max-w-2xl md:mt-14">
      <h2 class="reveal font-display" style="font-size: clamp(2rem, 5vw, 3.75rem); line-height: 1.05;">
        {advantages.heading}
      </h2>
    </div>

    <!-- Stats -->
    <div class="mt-14 grid grid-cols-2 gap-y-10 gap-x-6 border-y border-[var(--color-ink)]/15 py-12 md:mt-16 lg:grid-cols-4">
      {
        advantages.stats.map((s, i) => (
          <div class="reveal" style={`--reveal-delay: ${i * 70}ms;`}>
            <p class="font-display" style="font-size: clamp(2.75rem, 6vw, 4.5rem); line-height: 1;">
              {s.value}<span class="text-[var(--color-accent-deep)]">{s.suffix}</span>
            </p>
            <p class="mt-3 max-w-[16rem] text-sm leading-relaxed text-[var(--color-ink-soft)]">{s.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
