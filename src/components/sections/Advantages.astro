---
import SectionHead from "../SectionHead.astro";
import { advantages } from "../../data/content";
---

<section id="advantages" class="bg-void flex min-h-[100svh] flex-col justify-center py-[var(--spacing-section)]">
  <div class="container-luma">
    <SectionHead index={advantages.index} label={advantages.label} />

    <div class="mt-10 max-w-2xl md:mt-14">
      <h2 class="reveal font-display text-chalk" style="font-size: clamp(2rem, 5vw, 3.75rem); line-height: 1.05;">
        {advantages.heading}
      </h2>
    </div>

    <!-- Stats -->
    <div class="mt-14 grid grid-cols-2 gap-y-10 gap-x-6 border-y border-graphite py-12 md:mt-16 lg:grid-cols-4">
      {
        advantages.stats.map((s, i) => (
          <div class="reveal" style={`--reveal-delay: ${i * 70}ms;`}>
            <p class="font-display text-chalk" style="font-size: clamp(2.75rem, 6vw, 4.5rem); line-height: 1;">
              {s.value}<span class="text-[var(--color-accent)]">{s.suffix}</span>
            </p>
            <p class="mt-3 max-w-[16rem] text-sm leading-relaxed text-bone">{s.label}</p>
          </div>
        ))
      }
    </div>

    <!-- Principles -->
    <div class="mt-14 grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
      {
        advantages.principles.map((p, i) => (
          <div class="reveal" style={`--reveal-delay: ${(i % 4) * 70}ms;`}>
            <span class="meta text-[var(--color-accent)]">0{i + 1}</span>
            <h3 class="mt-4 font-display text-xl text-chalk md:text-2xl">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-bone">{p.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
