---
import SectionHead from "../SectionHead.astro";
import { problems } from "../../data/content";
---

<section id="problems" class="bg-void flex min-h-[100svh] flex-col justify-center py-[var(--spacing-section)]">
  <div class="container-luma">
    <SectionHead index={problems.index} label={problems.label} />

    <div class="mt-10 max-w-2xl md:mt-14">
      <h2 class="reveal font-display text-chalk" style="font-size: clamp(2rem, 5vw, 3.75rem); line-height: 1.05;">
        {problems.heading}
      </h2>
    </div>

    <div class="mt-12 grid gap-4 md:mt-16 md:grid-cols-2 md:gap-x-10 md:gap-y-5">
      {
        problems.items.map((item, i) => (
          <div
            class="reveal flex flex-wrap items-center gap-x-4 gap-y-2 border-b border-graphite py-5"
            style={`--reveal-delay: ${(i % 2) * 70}ms;`}
          >
            <span class="badge shrink-0">{item.problem}</span>
            <p class="text-base leading-relaxed text-bone">{item.approach}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
