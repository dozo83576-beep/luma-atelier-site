---
import SectionHead from "../SectionHead.astro";
import { procedures } from "../../data/content";
---

<section id="procedures" class="bg-umber flex min-h-[100svh] flex-col justify-center py-[var(--spacing-section)]">
  <div class="container-luma">
    <SectionHead index="05" label="Процедуры и стоимость" />

    <div class="mt-10 flex flex-col justify-between gap-6 md:mt-14 lg:flex-row lg:items-end">
      <h2 class="reveal max-w-xl font-display text-chalk" style="font-size: clamp(2rem, 5vw, 3.75rem); line-height: 1.05;">
        Прозрачный прайс. Никаких скрытых пакетов
      </h2>
      <p class="reveal text-sm text-bone" style="--reveal-delay: 100ms;">
        Точная стоимость зависит от состояния кожи и подбирается на консультации.
      </p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4 md:mt-16">
      {
        procedures.map((p, i) => (
          <article
            class="reveal group flex flex-col overflow-hidden rounded-xl border border-graphite bg-carbon transition-colors duration-500 hover:border-[var(--color-accent)]/40"
            style={`--reveal-delay: ${(i % 4) * 60}ms;`}
          >
            <div class="relative aspect-[4/5] overflow-hidden">
              <img
                src={p.img}
                alt={p.alt}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1.2s] ease-out group-hover:scale-105"
              />
              <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(20,16,12,0.05) 0%, rgba(20,16,12,0.35) 45%, rgba(20,16,12,0.92) 100%);" />
              <div class="absolute inset-x-0 top-0 p-4">
                <span class="badge">{p.category}</span>
              </div>
              <div class="absolute inset-x-0 bottom-0 p-4">
                <h3 class="font-display text-xl text-chalk">{p.name}</h3>
              </div>
            </div>

            <div class="flex flex-1 flex-col p-5">
              <p class="text-sm leading-relaxed text-bone">{p.desc}</p>
              <div class="mt-4 flex items-center justify-between border-t border-graphite pt-4">
                <div>
                  <span class="block text-xs text-smoke">{p.duration}</span>
                  <span class="font-display text-lg text-chalk">{p.priceFrom}</span>
                </div>
                <a href="#booking" class="text-xs text-bone transition-colors hover:text-[var(--color-accent)]">
                  Записаться →
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div class="reveal mt-10">
      <a href="#booking" class="pill pill-ghost">Подобрать процедуру на консультации</a>
    </div>
  </div>
</section>
