---
import SectionHead from "../SectionHead.astro";
import { programs } from "../../data/content";
---

<section id="programs" class="bg-void flex min-h-[100svh] flex-col justify-center py-[var(--spacing-section)]">
  <div class="container-luma">
    <SectionHead index="03" label="Персональные программы" />

    <div class="mt-10 flex flex-col justify-between gap-6 md:mt-14 lg:flex-row lg:items-end">
      <h2 class="reveal max-w-xl font-display text-chalk" style="font-size: clamp(2rem, 5vw, 3.75rem); line-height: 1.05;">
        Не отдельные процедуры, а путь к состоянию кожи
      </h2>
      <p class="reveal max-w-sm text-bone leading-relaxed" style="--reveal-delay: 100ms;">
        Каждая программа начинается с диагностики и заканчивается планом домашнего ухода. Мы ведём вас от первого визита до устойчивого результата.
      </p>
    </div>

    <div class="mt-12 grid gap-5 md:mt-16 lg:grid-cols-3">
      {
        programs.map((p, i) => (
          <article
            class="reveal flex flex-col rounded-xl border border-graphite bg-carbon p-7 transition-colors duration-500 hover:border-[var(--color-accent)]/40 md:p-8"
            style={`--reveal-delay: ${i * 90}ms;`}
          >
            <div class="flex items-center justify-between">
              <span class="ghost-index">{p.num}</span>
              <span class="badge">{p.duration}</span>
            </div>

            <h3 class="mt-8 font-display text-3xl text-chalk md:text-4xl">{p.title}</h3>
            <p class="mt-1 text-sm text-[var(--color-accent)]">{p.tagline}</p>
            <p class="mt-4 text-bone leading-relaxed">{p.desc}</p>

            <ul class="mt-7 space-y-3 border-t border-graphite pt-6">
              {p.steps.map((s, si) => (
                <li class="flex items-baseline gap-3 text-sm text-bone">
                  <span class="font-mono text-[0.7rem] text-smoke">0{si + 1}</span>
                  <span>{s}</span>
                </li>
              ))}
            </ul>

            <div class="mt-8 flex items-center justify-between border-t border-graphite pt-6">
              <span class="font-display text-xl text-chalk">{p.priceFrom}</span>
              <a href="#booking" class="text-sm text-bone transition-colors hover:text-[var(--color-accent)]">
                Записаться →
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
