---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.tsx";
import Method from "../components/sections/Method.astro";
import Directions from "../components/sections/Directions.astro";
import Programs from "../components/sections/Programs.astro";
import Problems from "../components/sections/Problems.astro";
import Procedures from "../components/sections/Procedures.astro";
import Atmosphere from "../components/sections/Atmosphere.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import Team from "../components/sections/Team.astro";
import Faq from "../components/sections/Faq.astro";
import Booking from "../components/sections/Booking.astro";
import Footer from "../components/sections/Footer.astro";
---

<Base>
  <a id="top"></a>
  <Nav />
  <main>
    <Hero client:load />
    <Method />
    <Directions />
    <Programs />
    <Problems />
    <Procedures />
    <Atmosphere />
    <Testimonials />
    <Team />
    <Faq />
    <Booking />
  </main>
  <Footer />
</Base>
